    "name": "E-Learning API",
    "description": "Dokumentasi Postman untuk API Laravel E-Learning. Set variable `base_url` sesuai server lokal, contoh `http://127.0.0.1:8000`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "topic_id",
      "value": "1"
    },
    {
      "key": "learning_material_id",
      "value": "1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Login user. Controller saat ini mengembalikan data user, belum mengembalikan token."
          }
        },
        {
          "name": "Get Authenticated User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "user"
              ]
            },
            "description": "Endpoint bawaan Sanctum. Isi variable `token` jika autentikasi token sudah dibuat."
          }
        }
      ]
    },
